# ThreatHunt AI Creator — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your API keys:
#
#   cp .env.example .env
#   nano .env
#
# The .env file is loaded automatically at startup (python-dotenv).
# It is listed in .gitignore — never commit it with real keys.
# ─────────────────────────────────────────────────────────────────────────────


# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Required for:
#   - Classic pipeline  → sidebar: Provider = "Claude (Anthropic API)"
#   - Multi-Agent pipeline (default, all agents use Anthropic models)
# Get your key: https://console.anthropic.com/
#
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── OpenAI API (optional) ─────────────────────────────────────────────────────
# Required only if using OpenAI models in Classic or per-agent config.
# Get your key: https://platform.openai.com/api-keys
#
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Ollama — local models (optional) ─────────────────────────────────────────
# No API key needed. Ollama runs 100% locally (free).
# Install: https://ollama.com/download
#
# After installing, pull a model:
#   ollama pull llama3               # fast, lightweight
#   ollama pull llama3.1:70b         # better quality, needs ~40 GB RAM
#   ollama pull mixtral:8x7b         # MoE, good for long contexts
#
# By default Ollama listens on http://localhost:11434.
# If running on a different host or port, uncomment and set:
#
# OLLAMA_HOST=http://localhost:11434
